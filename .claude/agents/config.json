{
  "agents": {
    "frontend": {
      "name": "Frontend Agent",
      "expertise": ["React", "Next.js", "TypeScript", "Tailwind CSS", "shadcn/ui"],
      "responsibilities": [
        "Desenvolvimento de componentes React",
        "Interfaces do usuário",
        "State management com hooks",
        "Performance e otimização de renders",
        "Acessibilidade (WCAG)",
        "Responsividade"
      ],
      "file_patterns": [
        "components/**/*.tsx",
        "app/**/*.tsx",
        "hooks/**/*.ts",
        "styles/**/*.css"
      ],
      "reference_file": ".claude/agents/frontend-agent.md"
    },
    "database": {
      "name": "Database Agent",
      "expertise": ["PostgreSQL", "Supabase", "SQL", "Migrations", "RLS Policies"],
      "responsibilities": [
        "Design de schema",
        "Criação de migrations",
        "Otimização de queries",
        "Implementação de RLS policies",
        "Backup e restore",
        "Relacionamentos entre tabelas"
      ],
      "file_patterns": [
        "lib/supabase/**/*.ts",
        "supabase/migrations/**/*.sql",
        "backup_supabase/**/*"
      ],
      "reference_file": ".claude/agents/database-agent.md"
    },
    "planejamento": {
      "name": "Planejamento Agent",
      "expertise": ["React Flow", "date-fns", "Cronogramas", "Lógica de Produção"],
      "responsibilities": [
        "Lógica de planejamento de produção",
        "Cálculo de cronogramas",
        "Gerenciamento de etapas",
        "Visualização de fluxos",
        "Grupos de execução",
        "Timeline e calendários"
      ],
      "file_patterns": [
        "components/planejamento/**/*.tsx",
        "components/planejamento-fluxo.tsx",
        "lib/planejamento/**/*.ts",
        "types/planejamento.ts"
      ],
      "reference_file": ".claude/agents/planejamento-agent.md"
    },
    "debug": {
      "name": "Debug Agent",
      "expertise": ["Chrome DevTools", "React DevTools", "Performance Profiling", "Error Tracing"],
      "responsibilities": [
        "Investigação de bugs",
        "Análise de erros de console",
        "Performance debugging",
        "Memory leak detection",
        "Network analysis",
        "Solução de problemas"
      ],
      "file_patterns": [
        "**/*.tsx",
        "**/*.ts",
        "**/*.sql"
      ],
      "reference_file": ".claude/agents/debug-agent.md"
    }
  },
  "workflows": {
    "new_feature": [
      "frontend",
      "database"
    ],
    "bug_fix": [
      "debug"
    ],
    "planejamento_feature": [
      "planejamento",
      "frontend",
      "database"
    ],
    "performance_issue": [
      "debug",
      "database"
    ]
  },
  "project_context": {
    "name": "Sistema de Orçamentos",
    "type": "Multi-tenant SaaS Application",
    "tech_stack": {
      "frontend": "Next.js 15, React, TypeScript, Tailwind CSS",
      "backend": "Supabase (PostgreSQL)",
      "ui": "shadcn/ui, React Flow",
      "auth": "Supabase Auth (tenant-based)"
    },
    "architecture": "Multi-tenant com isolamento por tenant_id",
    "main_modules": [
      "Orçamentos",
      "Planejamento de Produção",
      "Cadastros (Clientes, Produtos, Materiais)",
      "Financeiro"
    ]
  }
}
