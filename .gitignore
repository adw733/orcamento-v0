# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings
.claude/settings.local.json

# Temporary files
nul

# Sistema de versão (não commitar)
sistema-versao/
*.bat
*.py
README_CORRECOES.md

# Backups locais (não commitar - dados sensíveis)
backup_antes_saas/
backup_supabase/*/dados/
